# ONDEWO NLU nodejs client SDK — examples configuration template.
#
# This is a NON-SECRET template. Copy real values in locally, but never commit secrets.
# Every example under examples/ loads this file via dotenv (path relative to the script),
# so the canonical variable names below are the single source of truth for all examples.

# --- Connection -------------------------------------------------------------
# Host and port of the NLU gRPC endpoint (Envoy).
ONDEWO_HOST=localhost
ONDEWO_PORT=50055

# --- Secure channel ---------------------------------------------------------
# ONDEWO_USE_SECURE_CHANNEL=true builds a TLS gRPC channel; false uses plaintext.
# ONDEWO_GRPC_CERT is an OPTIONAL path to a PEM root cert for the TLS channel
# (leave blank to use the system trust store).
ONDEWO_USE_SECURE_CHANNEL=false
ONDEWO_GRPC_CERT=

# --- Keycloak (offline-token / ROPC login) ----------------------------------
# Base Keycloak URL, realm and PUBLIC SDK client used by the offline-token flow.
KEYCLOAK_URL=https://auth.example.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
# Only set KEYCLOAK_CLIENT_SECRET for a confidential client (the public SDK client has none).
KEYCLOAK_CLIENT_SECRET=
# 2FA-exempt technical-user credentials.
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak server's TLS certificate (set false only for a self-signed local Envoy).
KEYCLOAK_VERIFY_SSL=true

# --- Service-specific: NLU --------------------------------------------------
# Max number of agents to request in a single ListAgents page.
ONDEWO_NLU_PAGE_SIZE=10000
